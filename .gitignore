# ─── Secrets ─── (NEVER commit)
.env
.env.notarize

# ─── Trained models ─── (heavy, regenerable from training; distributed via HF / GitHub Releases)
models/

# ─── Run artifacts ─── (logs, plots, metrics, Trainer checkpoints, W&B)
experiments/
wandb/

# ─── Datasets ─── (downloaded or generated by src/data_pipeline/)
dataset/raw/
dataset/synthetic/
dataset/processed/
dataset/validation/
dataset/subsets/

# ─── Desktop app build — PyInstaller ───
build/
dist/
installer_out/
build_env/

# ─── Desktop app build — Tauri ───
tauri/node_modules/
tauri/src-tauri/target/
tauri/src-tauri/gen/
# bundled Python sidecar (~1.8 GB, regenerated by build_sidecar.spec)
tauri/src-tauri/backend/

# ─── Python ───
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ─── OS / editor cruft ───
.DS_Store
Thumbs.db
*.log
