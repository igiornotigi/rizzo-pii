# macOS Developer ID signing + notarization credentials for build_mac.sh.
# Copy to .env.notarize (gitignored) and fill in. NEVER commit the real file.
#
# Get the exact identity string with:  security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
APPLE_ID="you@example.com"
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # app-specific password (account.apple.com)
APPLE_TEAM_ID="TEAMID"
