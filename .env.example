# Copy this file to ".env" and fill in your own keys. The real .env is gitignored.
# Every key is OPTIONAL — the project runs without any of them:
#   • no WANDB_API_KEY  -> Weights & Biases tracking is auto-disabled
#   • no GEMINI_API_KEY -> you simply can't regenerate the legal templates (the rest works)

# Weights & Biases — training run tracking
WANDB_API_KEY=
WANDB_PROJECT=pii-mmbert-it

# Google Gemini — used ONLY by src/data_pipeline/llm_template_bank.py to write legal templates
GEMINI_API_KEY=

# Server bind address — optional, can also be set via config.json or CLI --host/--port
# The precedence chain is: CLI args > env vars > config.json > default (127.0.0.1:5005)
# PII_HOST=127.0.0.1
# PII_PORT=5005
